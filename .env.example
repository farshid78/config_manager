# Telegram
BOT_TOKEN=your_bot_token_here
OWNER_ID=0
CHANNEL_USERNAME=@jojo_config

# Database
DATABASE_URL=sqlite+aiosqlite:///data/main.db

# App
PROJECT_NAME=Config Manager
DEBUG=false
LOG_LEVEL=INFO

# Scraper
SCRAPER_ENABLED=true
SCRAPER_INTERVAL=300

